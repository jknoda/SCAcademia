# JWT Configuration
JWT_SECRET=change-this-in-production
JWT_ACCESS_EXPIRES=3600
JWT_REFRESH_EXPIRES=604800
BCRYPT_ROUNDS=10

# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scacademia

# SMTP Email Configuration (real email sending)
# Option A (recommended for Gmail/Outlook): use SMTP_SERVICE + user/pass
# SMTP_SERVICE=gmail
# SMTP_USER=your-account@gmail.com
# SMTP_PASS=app-specific-password

# Option B (custom SMTP host)
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-user
# SMTP_PASS=your-password

# Sender identity
# SMTP_FROM_NAME=SCAcademia
# SMTP_FROM_EMAIL=no-reply@yourdomain.com
